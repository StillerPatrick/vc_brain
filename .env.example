DATABASE_URL=sqlite+aiosqlite:///./vc_brain.db

# Optional for public GitHub requests, recommended for a higher rate limit.
GITHUB_TOKEN=
GITHUB_GRAPHQL_URL=https://api.github.com/graphql
GITHUB_RATE_LIMIT_MAX_WAIT_SECONDS=60

# Required for LinkedIn scraping.
APIFY_API_TOKEN=
LINKEDIN_ACTOR_ID=harvestapi/linkedin-profile-posts

# Optional X auth_token cookie. Recommended because anonymous timelines are
# frequently blocked. Do not commit this value.
X_AUTH_TOKEN=
X_PAGE_TIMEOUT_MS=30000

# Required for personality analysis. Terra balances analysis quality and cost.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
OPENAI_TIMEOUT_SECONDS=60
MAX_PITCH_DECK_BYTES=20971520

# Comma-separated browser origins allowed to call FastAPI.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Browser-visible FastAPI base URL used by the Next.js frontend.
# The frontend proxies /backend to this server-side URL.
BACKEND_URL=http://127.0.0.1:8000

LOG_LEVEL=INFO
